#!groovy

properties([
  [
    $class       : 'GithubProjectProperty',
    displayName  : 'MediaViewer',
    projectUrlStr: 'https://github.com/hmcts/rpx-xui-media-viewer/'
  ],
  pipelineTriggers([
    [$class: 'GitHubPushTrigger']
  ])
])


@Library("Infrastructure@2.4.0")

def type = "nodejs"
def product = "xui"
def component = "media-viewer"
def channel   = '#xui-pipeline'

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)
def playwrightPreviewSmokeOutputRoot = 'functional-output/tests/playwright-smoke/preview'
def playwrightAatSmokeOutputRoot = 'functional-output/tests/playwright-smoke/aat'
def playwrightSmokeOdhinReportFile = 'xui-playwright-smoke.html'
def playwrightPreviewSupportOutputRoot = 'functional-output/tests/playwright-support/preview'
def playwrightAatSupportOutputRoot = 'functional-output/tests/playwright-support/aat'
def playwrightSupportOdhinReportFile = 'xui-playwright-support.html'

def playwrightBrowsersEnv = {
  ["PLAYWRIGHT_BROWSERS_PATH=${env.WORKSPACE}/.cache/ms-playwright"]
}

def configurePlaywrightSmoke = { String outputRoot, String reportTitle ->
  steps.sh("rm -rf -- '${outputRoot}'")
  env.PLAYWRIGHT_TEST_OUTPUT_DIR = "${outputRoot}/test-results"
  env.PLAYWRIGHT_HTML_REPORT = "${outputRoot}/html-report"
  env.PLAYWRIGHT_JUNIT_OUTPUT = "${outputRoot}/playwright-smoke-junit.xml"
  env.PLAYWRIGHT_REPORT_FOLDER = "${outputRoot}/odhin-report"
  env.PLAYWRIGHT_REPORT_INDEX_FILENAME = playwrightSmokeOdhinReportFile
  env.PLAYWRIGHT_REPORT_TITLE = reportTitle
}

def publishPlaywrightJUnit = { String testResults ->
  steps.junit(
    allowEmptyResults: false,
    testResults: testResults
  )
}

def hasPlaywrightJUnit = { String outputRoot ->
  steps.sh(
    returnStatus: true,
    script: "find '${outputRoot}' -type f -name '*junit.xml' -print -quit | grep -q ."
  ) == 0
}

def publishPlaywrightReport = { String outputRoot, String reportName, String reportFile, boolean requireJUnit = true ->
  steps.sh(
    "node scripts/ensure-odhin-report.js --report-dir '${outputRoot}/odhin-report' --report-file '${reportFile}' --suite-name '${reportName}'"
  )
  publishHTML([
    allowMissing         : true,
    alwaysLinkToLastBuild: true,
    keepAll              : true,
    reportDir            : "${outputRoot}/odhin-report",
    reportFiles          : reportFile,
    reportName           : reportName
  ])
  steps.archiveArtifacts(
    allowEmptyArchive: true,
    artifacts: "${outputRoot}/**"
  )
  if (hasPlaywrightJUnit(outputRoot)) {
    publishPlaywrightJUnit("${outputRoot}/**/*junit.xml")
  } else if (requireJUnit) {
    steps.error("No Playwright JUnit XML found for ${reportName} under ${outputRoot}")
  } else {
    echo "No Playwright JUnit XML found for ${reportName}; Odhín report publication was still completed."
  }
}

def runPlaywrightSupportTests = { String outputRoot, String reportTitle ->
  steps.sh("rm -rf -- '${outputRoot}'")
  withEnv(playwrightBrowsersEnv() + [
    "PLAYWRIGHT_TEST_OUTPUT_DIR=${outputRoot}/test-results",
    "PLAYWRIGHT_HTML_REPORT=${outputRoot}/html-report",
    "PLAYWRIGHT_JUNIT_OUTPUT=${outputRoot}/playwright-junit.xml",
    "PLAYWRIGHT_REPORT_FOLDER=${outputRoot}/odhin-report",
    "PLAYWRIGHT_REPORT_INDEX_FILENAME=${playwrightSupportOdhinReportFile}",
    "PLAYWRIGHT_REPORT_TITLE=${reportTitle}",
    'PLAYWRIGHT_SKIP_INSTALL=true'
  ]) {
    try {
      yarnBuilder.yarn('test:playwright:support')
    } finally {
      publishPlaywrightReport(outputRoot, reportTitle, playwrightSupportOdhinReportFile)
    }
  }
}

env.DOCASSEMBLY_URL = "http://dg-docassembly-aat.service.core-compute-aat.internal"
env.DM_STORE_APP_URL = "http://dm-store-aat.service.core-compute-aat.internal"
env.HRS_API_URL = "http://em-hrs-api-aat.service.core-compute-aat.internal"
env.ANNOTATION_API_URL = "http://em-anno-aat.service.core-compute-aat.internal"
env.ICP_API_URL = "https://em-icp.aat.platform.hmcts.net"
env.NPA_URL = "http://em-npa-aat.service.core-compute-aat.internal"
env.IDAM_URL = "https://idam-api.aat.platform.hmcts.net"
env.S2S_URL = "http://rpe-service-auth-provider-aat.service.core-compute-aat.internal"
env.REDIRECT_URL = "https://xui-media-viewer-aat.service.core-compute-aat.internal/oauth2/callback"
env.NODE_ENV="TEST"

def vaultOverrides = [
        'preview' : 'aat',
]

def secrets = [
        'rpx-${env}': [
          secret('microservicekey-em-gw', 'S2S_KEY'),
          secret('show-oauth2-token', 'IDAM_SECRET'),
          secret('ccd-user-email', 'CCD_CASEWORKER_E2E_EMAIL'),
          secret('ccd-user-password', 'CCD_CASEWORKER_E2E_PASSWORD'),
          secret('microservicekey-ccd-gw', 'MICROSERVICE_CCD_GW'),
          secret('idam-client-secret', 'IDAM_CLIENT_SECRET')
        ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
    [ $class: 'AzureKeyVaultSecret',
      secretType: 'Secret',
      name: secretName,
      version: '',
      envVariable: envVar
    ]
}

timeout(time: 80, unit: 'MINUTES') {
withPipeline(type, product, component) {
  enableSlackNotifications(channel)
  overrideVaultEnvironments(vaultOverrides)
  loadVaultSecrets(secrets)
  env.EXECUTE_E2E=false
  env.TEST_URL = 'https://xui-media-viewer-staging.service.core-compute-aat.internal/'
  onPR{
  env.EXECUTE_E2E=true
  }
  before('akschartsinstall') {
    onPR {
      if (!env.CHANGE_URL && env.BRANCH_NAME ==~ /^PR-\d+$/) {
        env.CHANGE_ID = env.CHANGE_ID ?: env.BRANCH_NAME.replaceFirst('^PR-', '')
        env.CHANGE_URL = "https://github.com/hmcts/rpx-xui-media-viewer/pull/${env.CHANGE_ID}"
        echo "Filled missing Jenkins PR CHANGE_URL from BRANCH_NAME=${env.BRANCH_NAME}"
      }
      if (!env.CHANGE_BRANCH && env.GIT_COMMIT) {
        env.CHANGE_BRANCH = env.GIT_COMMIT
        echo "Filled missing Jenkins PR CHANGE_BRANCH from GIT_COMMIT"
      }
    }
  }
  enableAksStagingDeployment()
  disableLegacyDeployment()

  afterSuccess('checkout') {
      env.PUPPETEER_CACHE_DIR = "${env.WORKSPACE}/.cache/puppeteer"
      env.PUPPETEER_SKIP_DOWNLOAD = 'true'
      env.PLAYWRIGHT_BROWSERS_PATH = "${env.WORKSPACE}/.cache/ms-playwright"
      stage('Media Viewer API Setup') {
        withEnv(playwrightBrowsersEnv()) {
          yarnBuilder.yarn('setup:api')
        }
      }
      stage('Puppeteer Chrome Install') {
        yarnBuilder.yarn('puppeteer:install')
        env.PUPPETEER_INSTALL_ALREADY_VERIFIED = 'true'
      }
      stage('Playwright Install Chromium') {
        withEnv(playwrightBrowsersEnv()) {
          yarnBuilder.yarn('test:setup:playwright-install-chromium')
          env.PLAYWRIGHT_SKIP_INSTALL = 'true'
        }
      }
  }

  afterSuccess('build') {
    yarnBuilder.yarn('build')
    yarnBuilder.yarn('copy:demo-files')
  }

  before('smoketest:preview') {
    configurePlaywrightSmoke(playwrightPreviewSmokeOutputRoot, 'PREVIEW RPX XUI Media Viewer Playwright Smoke')
  }

  afterAlways('smoketest:preview') {
    publishPlaywrightReport(playwrightPreviewSmokeOutputRoot, 'PREVIEW Playwright Smoke Test', playwrightSmokeOdhinReportFile, false)
  }

  afterSuccess('smoketest:preview') {
    stage('Playwright Viewer Support Test - preview') {
      runPlaywrightSupportTests(playwrightPreviewSupportOutputRoot, 'PREVIEW Playwright Viewer Support Test')
    }
  }

  afterAlways('functionalTest:preview') {
      publishHTML([
              allowMissing         : true,
              alwaysLinkToLastBuild: true,
              keepAll              : true,
              reportDir            : "functional-output/",
              reportFiles          : 'mv-e2e-result.html',
              reportName           : 'PREVIEW Functional Test'
      ])
  }

  before('smoketest:aat') {
    configurePlaywrightSmoke(playwrightAatSmokeOutputRoot, 'AAT RPX XUI Media Viewer Playwright Smoke')
  }

  afterAlways('smoketest:aat') {
    publishPlaywrightReport(playwrightAatSmokeOutputRoot, 'AAT Playwright Smoke Test', playwrightSmokeOdhinReportFile, false)
  }

  afterSuccess('smoketest:aat') {
    stage('Playwright Viewer Support Test - AAT') {
      runPlaywrightSupportTests(playwrightAatSupportOutputRoot, 'AAT Playwright Viewer Support Test')
    }
  }

  afterAlways('functionalTest:aat') {
      publishHTML([
              allowMissing         : true,
              alwaysLinkToLastBuild: true,
              keepAll              : true,
              reportDir            : "functional-output/",
              reportFiles          : 'mv-e2e-result.html',
              reportName           : 'AAT Functional Test'
      ])
  }
}
}
