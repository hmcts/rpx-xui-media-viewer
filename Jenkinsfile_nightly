#!groovy

properties([
  [
  $class       : 'GithubProjectProperty',
  displayName  : 'MediaViewer',
  projectUrlStr: 'https://github.com/hmcts/rpx-xui-media-viewer/'
  ],
  pipelineTriggers([
    cron('H 17 * * *')
  ]),
  parameters([
    string(name: 'ENVIRONMENT', defaultValue: 'aat', description: 'Environment to test'),
    string(name: 'IDAM_API_URL', defaultValue: 'https://idam-api.aat.platform.hmcts.net', description: 'The Url of IDAM'),
    string(name: 'S2S_PROVIDER_URL', defaultValue: 'http://rpe-service-auth-provider-aat.service.core-compute-aat.internal', description: 'The Url of S2S provider'),
    string(name: 'CCD_DATA_STORE_URL', defaultValue: 'http://ccd-data-store-api-aat.service.core-compute-aat.internal', description: 'The Url of ccd data store'),
    string(name: 'SecurityRules',
      defaultValue: 'https://raw.githubusercontent.com/hmcts/security-test-rules/master/conf/security-rules.conf',
      description: 'The URL you want to run these tests against'),
  ])
])

@Library("Infrastructure")

def type = "nodejs"
def product = "xui"
def component = "media-viewer"
def channel   = '#xui-pipeline'

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)
def playwrightOutputRoot = 'functional-output/tests/playwright'
def playwrightSmokeOutputRoot = 'functional-output/tests/playwright-smoke'
def playwrightOdhinReportFile = 'xui-playwright.html'
def playwrightSmokeOdhinReportFile = 'xui-playwright-smoke.html'

def playwrightBrowsersEnv = {
  ["PLAYWRIGHT_BROWSERS_PATH=${env.WORKSPACE}/.cache/ms-playwright"]
}

def publishPlaywrightJUnit = { String testResults ->
  steps.junit(
    allowEmptyResults: false,
    testResults: testResults
  )
}

def publishPlaywrightReport = { String outputRoot, String reportName, String reportFile ->
  steps.sh(
    "node scripts/ensure-odhin-report.js --report-dir '${outputRoot}/odhin-report' --report-file '${reportFile}' --suite-name '${reportName}'"
  )
  publishHTML([
    allowMissing         : true,
    alwaysLinkToLastBuild: true,
    keepAll              : true,
    reportDir            : "${outputRoot}/odhin-report",
    reportFiles          : reportFile,
    reportName           : reportName
  ])
  publishPlaywrightJUnit("${outputRoot}/**/*junit.xml")
  steps.archiveArtifacts(
    allowEmptyArchive: true,
    artifacts: "${outputRoot}/**"
  )
}

def vaultOverrides = [
  'aat' : params.ENVIRONMENT,
]

def secrets = [
  "rpx-${params.ENVIRONMENT}": [
    secret('microservicekey-em-gw', 'S2S_KEY'),
    secret('show-oauth2-token', 'IDAM_SECRET'),
    secret('ccd-user-email', 'CCD_CASEWORKER_E2E_EMAIL'),
    secret('ccd-user-password', 'CCD_CASEWORKER_E2E_PASSWORD'),
    secret('microservicekey-ccd-gw', 'MICROSERVICE_CCD_GW'),
    secret('idam-client-secret', 'IDAM_CLIENT_SECRET')
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

withNightlyPipeline(type, product, component) {
  env.TEST_URL = 'http://localhost:3000'
  env.IDAM_URL = params.IDAM_API_URL
  env.S2S_PROVIDER = params.S2S_PROVIDER_URL
  env.S2S_URL = params.S2S_PROVIDER_URL
  env.CCD_DATA_STORE_API_URL = params.CCD_DATA_STORE_URL
  env.DOCASSEMBLY_URL = "http://dg-docassembly-${params.ENVIRONMENT}.service.core-compute-${params.ENVIRONMENT}.internal"
  env.DM_STORE_APP_URL = "http://dm-store-${params.ENVIRONMENT}.service.core-compute-${params.ENVIRONMENT}.internal"
  env.HRS_API_URL = "http://em-hrs-api-${params.ENVIRONMENT}.service.core-compute-${params.ENVIRONMENT}.internal"
  env.ANNOTATION_API_URL = "http://em-anno-${params.ENVIRONMENT}.service.core-compute-${params.ENVIRONMENT}.internal"
  env.NPA_URL = "http://em-npa-${params.ENVIRONMENT}.service.core-compute-${params.ENVIRONMENT}.internal"
  env.ICP_API_URL = "https://em-icp.${params.ENVIRONMENT}.platform.hmcts.net"
  env.REDIRECT_URL = "https://xui-media-viewer-${params.ENVIRONMENT}.service.core-compute-${params.ENVIRONMENT}.internal/oauth2/callback"
  env.REFORM_ENVIRONMENT = params.ENVIRONMENT
  env.NODE_ENV = "TEST"
  env.RUNNING_ENV = params.ENVIRONMENT
  overrideVaultEnvironments(vaultOverrides)
  loadVaultSecrets(secrets)

  disableLegacyDeployment()
  enableSecurityScan()
  enableSlackNotifications(channel)
  enableFullFunctionalTest(60)
  enableCrossBrowserTest()

  afterSuccess('checkout') {
    env.PUPPETEER_CACHE_DIR = "${env.WORKSPACE}/.cache/puppeteer"
    env.PLAYWRIGHT_BROWSERS_PATH = "${env.WORKSPACE}/.cache/ms-playwright"
    stage('Yarn Install') {
      sh ("rm -rf node_modules")
      sh ("yarn cache clean")
      sh ('npm rebuild node-sass')
      sh ('yarn install --check-cache')
    }
    stage('Puppeteer Chrome Install') {
      yarnBuilder.yarn('puppeteer:install')
    }
    stage('Media Viewer Setup') {
      yarnBuilder.yarn('setup')
    }
    stage('Playwright Install Chromium') {
      withEnv(playwrightBrowsersEnv()) {
        yarnBuilder.yarn('test:setup:playwright-install-chromium')
        env.PLAYWRIGHT_SKIP_INSTALL = 'true'
      }
    }
  }

  afterSuccess('build') {
    yarnBuilder.yarn('build')
    stage('Start local AAT media viewer') {
      sh '''
        set +x
        export IDAM_PASSWORD="${IDAM_PASSWORD:-${CCD_CASEWORKER_E2E_PASSWORD:-}}"
        export NODE_CONFIG="$(node -e "console.log(JSON.stringify({ secrets: { 'em-showcase': { 'show-oauth2-token': process.env.IDAM_SECRET, 'microservicekey-em-gw': process.env.S2S_KEY, password: process.env.IDAM_PASSWORD } } }))")"
        JENKINS_NODE_COOKIE=dontKillMe nohup yarn start:api > local-aat-api.log 2>&1 &
        JENKINS_NODE_COOKIE=dontKillMe nohup yarn start:ng --host 0.0.0.0 > local-aat-ng.log 2>&1 &
        for attempt in $(seq 1 60); do
          if curl -fsS http://localhost:3000/ >/dev/null && curl -fsS http://localhost:1337/health | grep -q '"status":"UP"'; then
            echo "Local AAT media viewer is ready"
            exit 0
          fi
          sleep 2
        done
        echo "Local AAT media viewer did not become ready" >&2
        tail -100 local-aat-api.log >&2 || true
        tail -100 local-aat-ng.log >&2 || true
        exit 1
      '''
    }
    stage('Playwright Runner Baseline') {
      withEnv(playwrightBrowsersEnv() + [
        "PLAYWRIGHT_TEST_OUTPUT_DIR=${playwrightOutputRoot}/test-results",
        "PLAYWRIGHT_HTML_REPORT=${playwrightOutputRoot}/html-report",
        "PLAYWRIGHT_JUNIT_OUTPUT=${playwrightOutputRoot}/playwright-junit.xml",
        "PLAYWRIGHT_REPORT_FOLDER=${playwrightOutputRoot}/odhin-report",
        "PLAYWRIGHT_REPORT_INDEX_FILENAME=${playwrightOdhinReportFile}",
        "PLAYWRIGHT_REPORT_TITLE=Nightly RPX XUI Media Viewer Playwright Runner Baseline",
        "PLAYWRIGHT_BASE_URL=http://localhost:3000/",
        "PLAYWRIGHT_SKIP_INSTALL=true"
      ]) {
        try {
          yarnBuilder.yarn('test:playwright')
        } finally {
          publishPlaywrightReport(playwrightOutputRoot, 'Nightly Playwright Runner Baseline', playwrightOdhinReportFile)
        }
      }
    }
    stage('Playwright Smoke Test') {
      withEnv(playwrightBrowsersEnv() + [
        "PLAYWRIGHT_TEST_OUTPUT_DIR=${playwrightSmokeOutputRoot}/test-results",
        "PLAYWRIGHT_HTML_REPORT=${playwrightSmokeOutputRoot}/html-report",
        "PLAYWRIGHT_JUNIT_OUTPUT=${playwrightSmokeOutputRoot}/playwright-smoke-junit.xml",
        "PLAYWRIGHT_REPORT_FOLDER=${playwrightSmokeOutputRoot}/odhin-report",
        "PLAYWRIGHT_REPORT_INDEX_FILENAME=${playwrightSmokeOdhinReportFile}",
        "PLAYWRIGHT_REPORT_TITLE=Nightly RPX XUI Media Viewer Playwright Smoke",
        "PLAYWRIGHT_BASE_URL=http://localhost:3000/",
        "PLAYWRIGHT_SKIP_INSTALL=true"
      ]) {
        try {
          yarnBuilder.yarn('test:playwright:smoke')
        } finally {
          publishPlaywrightReport(playwrightSmokeOutputRoot, 'Nightly Playwright Smoke Test', playwrightSmokeOdhinReportFile)
        }
      }
    }
  }

  afterAlways('fullFunctionalTest') {
    publishHTML([
      allowMissing         : true,
      alwaysLinkToLastBuild: true,
      keepAll              : true,
      reportDir            : "functional-output",
      reportFiles          : 'mv-e2e-result.html',
      reportName           : 'Functional Tests'
    ])
  }

  afterAlways('crossBrowserTest') {
    publishHTML([
      allowMissing         : true,
      alwaysLinkToLastBuild: true,
      keepAll              : true,
      reportDir            : "functional-output",
      reportFiles          : 'index.html',
      reportName           : 'Cross Browser Tests'
    ])
  }

  afterAlways('securityScan') {
    publishHTML([
      allowMissing         : true,
      alwaysLinkToLastBuild: true,
      keepAll              : true,
      reportDir            : "reports/tests/",
      reportFiles          : 'activescan.html',
      reportName           : 'ZAP Security Scan Report'
    ])
  }
}
