#!groovy

def scheduledNightlyTriggers = env.BRANCH_NAME == 'master' ? [cron('H 17 * * *')] : []

properties([
  [
  $class       : 'GithubProjectProperty',
  displayName  : 'MediaViewer',
  projectUrlStr: 'https://github.com/hmcts/rpx-xui-media-viewer/'
  ],
  pipelineTriggers(scheduledNightlyTriggers),
  parameters([
    string(name: 'ENVIRONMENT', defaultValue: 'aat', description: 'Environment to test'),
    string(name: 'IDAM_API_URL', defaultValue: 'https://idam-api.aat.platform.hmcts.net', description: 'The Url of IDAM'),
    string(name: 'S2S_PROVIDER_URL', defaultValue: 'http://rpe-service-auth-provider-aat.service.core-compute-aat.internal', description: 'The Url of S2S provider'),
    string(name: 'CCD_DATA_STORE_URL', defaultValue: 'http://ccd-data-store-api-aat.service.core-compute-aat.internal', description: 'The Url of ccd data store'),
    string(name: 'SecurityRules',
      defaultValue: 'https://raw.githubusercontent.com/hmcts/security-test-rules/master/conf/security-rules.conf',
      description: 'The URL you want to run these tests against'),
  ])
])

@Library("Infrastructure")

def type = "nodejs"
def product = "xui"
def component = "media-viewer"
def channel   = '#xui-pipeline'

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

def vaultOverrides = [
  'aat' : params.ENVIRONMENT,
]

def secrets = [
  "rpx-${params.ENVIRONMENT}": [
    secret('microservicekey-em-gw', 'S2S_KEY'),
    secret('show-oauth2-token', 'IDAM_SECRET'),
    secret('password', 'IDAM_PASSWORD'),
    secret('ccd-user-email', 'CCD_CASEWORKER_E2E_EMAIL'),
    secret('ccd-user-password', 'CCD_CASEWORKER_E2E_PASSWORD'),
    secret('microservicekey-ccd-gw', 'MICROSERVICE_CCD_GW'),
    secret('idam-client-secret', 'IDAM_CLIENT_SECRET')
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

timeout(time: 60, unit: 'MINUTES') {
withNightlyPipeline(type, product, component) {
  env.TEST_URL = 'http://localhost:3000'
  env.IDAM_URL = params.IDAM_API_URL
  env.S2S_PROVIDER = params.S2S_PROVIDER_URL
  env.S2S_URL = params.S2S_PROVIDER_URL
  env.CCD_DATA_STORE_API_URL = params.CCD_DATA_STORE_URL
  env.DOCASSEMBLY_URL = "http://dg-docassembly-${params.ENVIRONMENT}.service.core-compute-${params.ENVIRONMENT}.internal"
  env.DM_STORE_APP_URL = "http://dm-store-${params.ENVIRONMENT}.service.core-compute-${params.ENVIRONMENT}.internal"
  env.HRS_API_URL = "http://em-hrs-api-${params.ENVIRONMENT}.service.core-compute-${params.ENVIRONMENT}.internal"
  env.ANNOTATION_API_URL = "http://em-anno-${params.ENVIRONMENT}.service.core-compute-${params.ENVIRONMENT}.internal"
  env.NPA_URL = "http://em-npa-${params.ENVIRONMENT}.service.core-compute-${params.ENVIRONMENT}.internal"
  env.ICP_API_URL = "https://em-icp.${params.ENVIRONMENT}.platform.hmcts.net"
  env.REDIRECT_URL = "https://xui-media-viewer-${params.ENVIRONMENT}.service.core-compute-${params.ENVIRONMENT}.internal/oauth2/callback"
  env.REFORM_ENVIRONMENT = params.ENVIRONMENT
  env.NODE_ENV = "TEST"
  env.RUNNING_ENV = params.ENVIRONMENT
  env.E2E_FAIL_FAST_PREFLIGHT = "true"
  overrideVaultEnvironments(vaultOverrides)
  loadVaultSecrets(secrets)

  disableLegacyDeployment()
  enableSlackNotifications(channel)
  enableFullFunctionalTest(60)

  afterSuccess('checkout') {
    env.PUPPETEER_CACHE_DIR = "${env.WORKSPACE}/.cache/puppeteer"
    stage('Yarn Install') {
      sh ("rm -rf node_modules")
      sh ("yarn cache clean")
      sh ('npm rebuild node-sass')
      sh ('yarn install --check-cache')
    }
    stage('Puppeteer Chrome Install') {
      yarnBuilder.yarn('puppeteer:install')
    }
    stage('Media Viewer Setup') {
      yarnBuilder.yarn('setup')
    }
  }

  afterSuccess('build') {
    yarnBuilder.yarn('build')
    stage('Start local AAT media viewer') {
      sh '''
        set +x
        export IDAM_PASSWORD="${IDAM_PASSWORD:-${CCD_CASEWORKER_E2E_PASSWORD:-}}"
        export NODE_CONFIG="$(node -e "const secrets = { 'show-oauth2-token': process.env.IDAM_SECRET, 'microservicekey-em-gw': process.env.S2S_KEY, password: process.env.IDAM_PASSWORD }; console.log(JSON.stringify({ secrets: { rpx: secrets, 'em-showcase': secrets } }))")"

        rm -f local-aat-api.log local-aat-ng.log
        JENKINS_NODE_COOKIE=dontKillMe nohup yarn start:api > local-aat-api.log 2>&1 &
        api_pid=$!

        for attempt in $(seq 1 60); do
          if ! kill -0 "$api_pid" 2>/dev/null; then
            echo "Local AAT API exited before becoming ready" >&2
            tail -200 local-aat-api.log >&2 || true
            exit 1
          fi

          if curl -fsS http://localhost:1337/health 2>/dev/null | grep -q '"status":"UP"'; then
            echo "Local AAT API is ready"
            break
          fi

          if grep -q "Could not start" local-aat-api.log; then
            echo "Local AAT API startup failed" >&2
            tail -200 local-aat-api.log >&2 || true
            exit 1
          fi

          sleep 2
        done

        if ! curl -fsS http://localhost:1337/health 2>/dev/null | grep -q '"status":"UP"'; then
          echo "Local AAT API did not become ready" >&2
          tail -200 local-aat-api.log >&2 || true
          exit 1
        fi

        JENKINS_NODE_COOKIE=dontKillMe nohup yarn start:ng --host 0.0.0.0 > local-aat-ng.log 2>&1 &
        ng_pid=$!

        for attempt in $(seq 1 90); do
          if ! kill -0 "$ng_pid" 2>/dev/null; then
            echo "Local AAT Angular host exited before becoming ready" >&2
            tail -200 local-aat-ng.log >&2 || true
            exit 1
          fi

          if curl -fsS http://localhost:3000/ >/dev/null 2>&1; then
            echo "Local AAT media viewer is ready"
            exit 0
          fi

          sleep 2
        done

        echo "Local AAT media viewer did not become ready" >&2
        tail -200 local-aat-api.log >&2 || true
        tail -200 local-aat-ng.log >&2 || true
        exit 1
      '''
    }
  }

  afterAlways('fullFunctionalTest') {
    publishHTML([
      allowMissing         : true,
      alwaysLinkToLastBuild: true,
      keepAll              : true,
      reportDir            : "functional-output",
      reportFiles          : 'mv-e2e-result.html',
      reportName           : 'Functional Tests'
    ])
  }

}
}
